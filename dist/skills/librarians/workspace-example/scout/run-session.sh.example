#!/bin/bash
# Example launchd/cron wrapper for the omoikane scout librarian.
# Copy to your workspace, replace the placeholders, make executable.
#
# Placeholders:
#   <NODE_BIN_DIR>  dir holding the `pi` runtime (e.g. ~/.nvm/.../bin)
#   <WORKSPACE>     absolute path to this workspace dir
set -euo pipefail

# launchd/cron give a bare environment; set PATH so curl/jq/pi/python resolve.
export PATH="<NODE_BIN_DIR>:/opt/homebrew/bin:/usr/bin:/bin"

WORKDIR="<WORKSPACE>"
LOCK="$WORKDIR/.scout-session.lock"
cd "$WORKDIR"
ts() { date '+%Y-%m-%dT%H:%M:%S'; }

# Single-flight: skip if a prior run is still going.
if ! mkdir "$LOCK" 2>/dev/null; then
    echo "$(ts) [skip] a scout session is already running"; exit 0
fi
trap 'rmdir "$LOCK" 2>/dev/null || true' EXIT

echo "=== $(ts) scout START ==="
# pi reads its model creds from ~/.pi/agent/auth.json (HOME-based);
# omoikane creds come from .agents/.local/kb-agent.json (NOT via env).
pi --print --skill .agents/skills/omoikane-scout --no-context-files \
   "Scout run: fetch all allow-listed sources, judge novelty/value, post only high-value (cap 5) as DRAFT external_finding, mark rest seen, then summary line."
rc=$?
echo "=== $(ts) scout END (rc=$rc) ==="
exit $rc
